# Deny access to backup files
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^.*$ - [F,L]
</IfModule>

# Fallback for servers without mod_rewrite
<IfModule !mod_rewrite.c>
    Deny from all
</IfModule>

# Block all file types
<FilesMatch ".*">
    Order Allow,Deny
    Deny from all
</FilesMatch>
