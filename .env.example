# ============================================
# TheBigFive Payroll System — Environment Config
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# Application
APP_ENV=local
APP_DEBUG=false
APP_NAME="TheBigFive Payroll System"
APP_URL=http://localhost/thebigfive

# Database
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=thebigfive_payroll
DB_USERNAME=root
DB_PASSWORD=

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME="TheBigFive Payroll System"

# Session
SESSION_LIFETIME=480
